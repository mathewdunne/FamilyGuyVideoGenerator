# Copy this file to .env and fill in your local values.

# OpenRouter script generation
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional OpenRouter app attribution headers.
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=FamilyGuyVideoGenerator

# Fish Audio
FISH_AUDIO_API_KEY=
FISH_AUDIO_PETER_VOICE_ID=
FISH_AUDIO_STEWIE_VOICE_ID=
FISH_AUDIO_MODEL=s2-pro

# Optional. Usually not needed if `magick -version` works in the same terminal.
# Example Windows path:
# IMAGEMAGICK_BINARY=C:\Program Files\ImageMagick-7.1.2-Q16-HDRI\magick.exe

# Optional alias also supported by the app:
# FISH_API_KEY=
